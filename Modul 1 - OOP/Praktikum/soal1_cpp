class Pemain 
{
protected:
    string nama;
    int koin,exp,tt;
public:
//constructor
    Pemain(string n, int k, int e, int Tt)
    {
        nama = n;
        koin = k;
        exp = e;
        tt = Tt;
    }
//setter getter
    //setter getter "Nama"
void setNama (string n)
{
    nama = n;
}
string getNama ()
{
    return nama;
}
    //setter getter "Koin"
void setKoin (int k)
{
    koin = k;
}
int getKoin ()
{
    return koin;
}
    //setter getter "Exp"
void setExp (int e)
{
    exp = e;
}
int getExp ()
{
    return exp;
}
    //setter getter "Tt"
void setTt (int Tt)
{
    tt = Tt;
}
int getTt ()
{
    return tt;
}
virtual void hunt(int baseKoin, int baseExp);
virtual void info();
virtual ~Pemain();
};

class PemainSolo : public Pemain
{
public:
//constructor
PemainSolo (string n, int k, int e, int Tt) : Pemain (n, k, e, Tt) {}
//Override
void hunt(int baseKoin, int baseExp) override
{
    koin = baseKoin;
    exp = baseExp * (1+tt);  
}
void info()
{
    cout << "[SOLO]" << " | " << nama << " | Koin: " << koin << " | EXP: " << exp << " | TT: " << tt;
}
};

class PemainParty : public Pemain 
{

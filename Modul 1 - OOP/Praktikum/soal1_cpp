int partySize;

public:
//constructor
PemainParty (string n, int k, int e, int Tt, int partySize) : Pemain (n, k, e, Tt) 
{
this->partySize = partySize;
}
//setter getter
    //setter getter "partySize"
void setpartySize (int p)
{
    partySize = p;
}
int getExp ()
{
    return partySize;
}
//Override
void hunt(int baseKoin, int baseExp) override
{
    koin = baseKoin / partySize;
    exp = baseExp * (1+tt);  
